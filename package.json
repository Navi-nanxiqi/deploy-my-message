{
  "name": "nest-app",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev":"nest start --watch",
    "start": "npm run build:web && nest start --watch",
    "start:dev": "node -e \"const fs=require('fs');const cp=require('child_process');if(fs.existsSync('src/web/dist')){cp.execSync('nest start --watch',{stdio:'inherit'});}else{cp.execSync('npm run build:web',{stdio:'inherit'});cp.execSync('nest start --watch',{stdio:'inherit'});}\"",
    "build:api": "nest build",
    "build:web": "npm run --prefix src/web build",
    "build": "npm run build:api && npm run build:web",
    "lint:web": "npm run --prefix src/web lint",
    "bootstrap": "npm ci && npm ci --prefix src/web"
  },
  "dependencies": {
    "@casl/ability": "^6.7.5",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.5",
    "bullmq": "^5.66.4",
    "class-transformer": "^0.5.1",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "md5": "^2.3.0",
    "nanoid": "^5.1.6",
    "nodemailer": "^7.0.11",
    "path": "^0.12.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sqlite3": "^5.1.7",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/common": "^11.1.12",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/bull": "^3.15.9",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^30.0.0",
    "@types/md5": "^2.3.6",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "class-validator": "^0.14.3",
    "cpr": "^3.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "make-dir-cli": "^4.0.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.4.2",
    "rimraf": "^6.1.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.27",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "node_modules/(?!(nanoid)/)"
    ]
  }
}
